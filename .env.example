# Fraud Detection System - Environment Configuration
# Copy this file to .env and fill in your API keys

# ==================== LLM PROVIDERS ====================
# Choose at least ONE to enable LLM explanations
# Priority: Gemini > Groq > HuggingFace

# Google Gemini AI (Recommended)
# Get key at: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=api


# Groq API (Ultra-fast LLM)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=api

# HuggingFace API (Open-source models)
# Get token at: https://huggingface.co/settings/tokens
OPEN_ROUTER_API_KEY=api
# ==================== DATABASE (OPTIONAL) ====================
# If not set, system works with in-memory model only
DATABASE_URL=url
# ==================== REDIS CACHE (OPTIONAL) ====================
# If not set, Redis is disabled gracefully
REDIS_URL=redis://localhost:6379

# ==================== APPLICATION ====================
APP_NAME=Fraud Detection System
APP_VERSION=1.0.0
DEBUG=False
